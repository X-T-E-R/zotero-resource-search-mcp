{
  "id": "semantic",
  "name": "Semantic Scholar",
  "version": "1.0.0",
  "sourceType": "academic",
  "description": "Semantic Scholar Graph API",
  "minPluginVersion": "0.1.0",
  "permissions": {
    "urls": ["https://api.semanticscholar.org/*"]
